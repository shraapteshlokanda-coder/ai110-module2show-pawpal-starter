classDiagram
    class Owner {
        +String name
        +int available_minutes_per_day
        +dict preferences
        +list~Pet~ pets
        +add_pet(pet)
        +remove_pet(pet_name)
        +find_pet(pet_name)
        +all_tasks(include_completed=False)
    }

    class Pet {
        +String name
        +String species
        +int age
        +list~Task~ tasks
        +add_task(task)
        +remove_task(title)
        +update_task(title, **kwargs)
        +list_tasks()
        +mark_task_complete(title)
    }

    class Task {
        +String title
        +int duration_minutes
        +String priority
        +String description
        +String preferred_time
        +date due_date
        +String frequency
        +bool completed
        +summary()
        +priority_score()
        +mark_complete()
    }

    class PawPalScheduler {
        +Owner owner
        +get_all_tasks(include_completed=False)
        +generate_daily_plan(pet_name=None, date=None)
        +sort_by_time(tasks)
        +filter_tasks(tasks, pet_name=None, include_completed=None)
        +detect_conflicts(tasks)
    }

    Owner --> "0..*" Pet : owns
    Pet --> "0..*" Task : has
    PawPalScheduler --> Owner : uses
    PawPalScheduler --> Pet : schedules
